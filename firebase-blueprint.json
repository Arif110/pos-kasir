{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product inventory item",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" }
      },
      "required": ["code", "name", "category", "price", "purchasePrice", "stock", "minStock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "POS sales transaction",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "totalProfit": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["CASH", "QRIS", "DEBT"] },
        "amountPaid": { "type": "number" },
        "change": { "type": "number" },
        "customerName": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["invoiceNumber", "date", "items", "total", "totalProfit", "paymentType", "amountPaid", "change"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Customer debt ledger",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "totalDebt": { "type": "number" },
        "remainingDebt": { "type": "number" },
        "dueDate": { "type": "string" },
        "status": { "type": "string", "enum": ["UNPAID", "PARTIAL", "PAID"] },
        "payments": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "customerPhone", "totalDebt", "remainingDebt", "dueDate", "status", "payments", "createdAt"]
    },
    "ShopSettings": {
      "title": "ShopSettings",
      "description": "Shop configuration profile",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "shopAddress": { "type": "string" },
        "shopPhone": { "type": "string" },
        "qrisText": { "type": "string" },
        "receiptFooter": { "type": "string" },
        "currencySymbol": { "type": "string" }
      },
      "required": ["shopName", "shopAddress", "shopPhone", "qrisText", "receiptFooter", "currencySymbol"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Inventory products collection"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "POS transactions collection"
    },
    "debts/{debtId}": {
      "schema": "Debt",
      "description": "Customer debts ledger collection"
    },
    "settings/{settingId}": {
      "schema": "ShopSettings",
      "description": "Settings singletons collection"
    }
  }
}
